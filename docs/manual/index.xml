/docs/manual/generating-catalog/vscode-kaoto-settings_huf56e2cd9939d9a2b1e6833ababe595d8_37691_c8879722ed886b00d13c42c7745a5fe6.webp 760w,
/docs/manual/generating-catalog/vscode-kaoto-settings_huf56e2cd9939d9a2b1e6833ababe595d8_37691_1200x1200_fit_q95_h2_lanczos_3.webp 1200w"
